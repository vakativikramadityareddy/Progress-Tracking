{
  "name": "team-task-manager",
  "version": "1.0.0",
  "description": "Team Task Manager Fullstack App",
  "scripts": {
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "db:push": "npx prisma db push --schema=backend/prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema=backend/prisma/schema.prisma",
    "db:studio": "npx prisma studio --schema=backend/prisma/schema.prisma"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2"
  }
}
